# ----------------------------------------------------------------------------
# Axploria environment variables
# Copy this file to ".env.local" for local dev, and add the same values as
# repository secrets / Pages environment variables in production.
# ----------------------------------------------------------------------------

# Public base URL of the deployed site (used for canonical URLs, sitemap, OG).
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://axploria.pages.dev

# Google Gemini API key — used ONLY by the discovery pipeline (scripts/fetch-tools.mjs),
# never shipped to the browser. Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_free_gemini_api_key_here

# Optional: override the Gemini model used for classification.
# Defaults to "gemini-2.0-flash" (free tier) if unset.
GEMINI_MODEL=gemini-2.0-flash
