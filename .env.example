# ----------------------------------------------------------------------------
# Axploria environment variables
# Copy this file to ".env.local" for local dev, and add the same values as
# repository secrets / Pages environment variables in production.
# ----------------------------------------------------------------------------

# Public base URL of the deployed site (used for canonical URLs, sitemap, OG).
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://axploria.pages.dev

# Groq API key — used ONLY by the discovery pipeline (scripts/fetch-tools.mjs),
# never shipped to the browser. Get a free key (no credit card) at https://console.groq.com/keys
GROQ_API_KEY=your_free_groq_api_key_here

# Optional: override the Groq model used for classification.
# Defaults to "llama-3.3-70b-versatile" (free tier) if unset.
GROQ_MODEL=llama-3.3-70b-versatile
