# ----------------------------------------------------------------------------
# Axploria environment variables
# Copy this file to ".env.local" for local dev, and add the same values as
# repository secrets / Pages environment variables in production.
# ----------------------------------------------------------------------------

# Public base URL of the deployed site (used for canonical URLs, sitemap, OG).
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://axploria.pages.dev

# The discovery pipeline (scripts/fetch-tools.mjs) classifies candidates with
# GitHub Models. In GitHub Actions it uses the built-in GITHUB_TOKEN automatically —
# nothing to configure. For LOCAL runs only, set a GitHub PAT with the "models:read"
# scope here so the script can authenticate:
GH_MODELS_TOKEN=your_github_pat_with_models_read

# Optional: override the model used for classification.
# Defaults to "openai/gpt-4o-mini" if unset.
LLM_MODEL=openai/gpt-4o-mini
